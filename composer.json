{
    "name": "vjik/my-prompts-mcp",
    "description": "MCP server that provides user prompts",
    "license": "BSD-3-Clause",
    "type": "project",
    "authors": [
        {
            "name": "Sergei Predvoditelev",
            "email": "sergei@predvoditelev.ru"
        }
    ],
    "support": {
        "issues": "https://github.com/vjik/my-prompts-mcp/issues?state=open",
        "chat": "https://t.me/predvoditelev_chat",
        "source": "https://github.com/vjik/my-prompts-mcp"
    },
    "funding": [
        {
            "type": "cloudtips",
            "url": "https://pay.cloudtips.ru/p/192ce69b"
        },
        {
            "type": "boosty",
            "url": "https://boosty.to/vjik"
        }
    ],
    "require": {
        "php": "^8.5",
        "logiscape/mcp-sdk-php": "^1.5.1",
        "spatie/yaml-front-matter": "^2.1.1"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.9.1",
        "buggregator/trap": "^1.15.2",
        "phpstan/phpstan": "^2.1.46"
    },
    "autoload": {
        "psr-4": {
            "Vjik\\MyPromptsMcp\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "php-http/discovery": false
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "forward-command": true,
            "target-directory": "tools"
        }
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "dependency-analyser": "composer-dependency-analyser",
        "phpstan": "phpstan analyse -c phpstan.neon"
    }
}
